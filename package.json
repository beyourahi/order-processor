{
    "name": "order-processor",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vite dev --open --host",
        "sync-ds": "rsync -a --delete ../../dropout-design-system/src/lib/ ./src/lib/ds/",
        "build": "vite build",
        "preview": "bun run build && wrangler dev",
        "deploy": "bun run build && wrangler deploy",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "cf-typegen": "wrangler types",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:pull": "drizzle-kit pull",
        "db:studio": "drizzle-kit studio",
        "db:check": "drizzle-kit check",
        "db:migrate": "wrangler d1 migrations apply order_processor --remote",
        "db:migrate:local": "wrangler d1 migrations apply order_processor --local",
        "db:migrate:list": "wrangler d1 migrations list order_processor --local"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/kit": "^2.68.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^26.0.1",
        "@types/papaparse": "^5.5.2",
        "drizzle-kit": "0.31.10",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.7.0",
        "prettier": "^3.8.4",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "5.56.4",
        "svelte-check": "^4.7.1",
        "tailwindcss": "^4.3.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "wrangler": "^4.105.0"
    },
    "dependencies": {
        "@better-auth/passkey": "1.6.20",
        "@lucide/svelte": "^1.21.0",
        "better-auth": "^1.6.20",
        "bits-ui": "^2.18.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "gsap": "^3.15.0",
        "papaparse": "^5.5.4",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "xlsx": "^0.18.5",
        "zod": "^4.4.3"
    },
    "type": "module"
}
