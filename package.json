{
    "name": "order-processor",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vite dev --open",
        "build": "vite build",
        "preview": "bun run build && wrangler dev",
        "deploy": "bun run build && wrangler deploy",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "cf-typegen": "wrangler types",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:pull": "drizzle-kit pull",
        "db:studio": "drizzle-kit studio",
        "db:check": "drizzle-kit check",
        "db:migrate": "wrangler d1 migrations apply order_processor --remote",
        "db:migrate:local": "wrangler d1 migrations apply order_processor --local",
        "db:migrate:list": "wrangler d1 migrations list order_processor --local"
    },
    "devDependencies": {
        "@sveltejs/adapter-cloudflare": "^7.2.5",
        "@sveltejs/kit": "^2.49.5",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^25.0.9",
        "@types/papaparse": "^5.5.2",
        "drizzle-kit": "0.31.8",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.14.0",
        "globals": "^17.0.0",
        "prettier": "^3.8.0",
        "prettier-plugin-svelte": "^3.4.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "svelte": "^5.46.4",
        "svelte-check": "^4.3.5",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.0",
        "vite": "^7.3.1",
        "wrangler": "^4.59.2"
    },
    "dependencies": {
        "better-auth": "^1.4.13",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.1",
        "papaparse": "^5.5.3",
        "tailwind-merge": "^3.4.0",
        "xlsx": "^0.18.5"
    },
    "type": "module"
}
