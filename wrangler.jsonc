{
    "$schema": "node_modules/wrangler/config-schema.json",
    "account_id": "75321bb4297a25f524624ba0f3f81443",
    "name": "order-processor",
    "main": ".svelte-kit/cloudflare/_worker.js",
    "compatibility_flags": ["nodejs_compat"],
    "compatibility_date": "2025-05-29",
    "assets": {
        "binding": "ASSETS",
        "directory": ".svelte-kit/cloudflare"
    },
    // D1 (SQLite): auth sessions, brand_settings, and Copilot chat history.
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "order_processor",
            "database_id": "ae9e0e94-99a1-485f-9ed0-c42ad70c6094",
            "migrations_dir": "migrations"
        }
    ],
    // Workers AI: required by /api/copilot/chat (returns 503 if absent), RAG
    // embeddings, and the seed endpoint. Rerun `bun run cf-typegen` after edits.
    "ai": {
        "binding": "AI"
    },
    // Copilot RAG knowledge store. Index dims must match the qwen3 embedding
    // model (1024); changing the model means recreating the index + re-seeding.
    "vectorize": [
        {
            "binding": "VECTORIZE",
            "index_name": "order-processor-kb"
        }
    ],
    "observability": {
        "enabled": true
    },
    "limits": {
        "cpu_ms": 300000
    },
    // AI_GATEWAY_SLUG keys the AI Gateway dynamic route `dynamic/copilot-chain`;
    // openGatewayChat() throws without it. The model cascade lives in the
    // Cloudflare dashboard route, NOT in code (CLAUDE.md #22).
    "vars": {
        "BETTER_AUTH_URL": "https://order-processor.beyourahi.workers.dev",
        "AI_GATEWAY_SLUG": "order-processor-ai"
    }
}
